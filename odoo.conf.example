[options]
db_host = postgres
db_port = 5432
db_user = odoo
db_password = False
db_name = newsassistant
db_filter = newsassistant
addons_path = /mnt/extra-addons,/mnt/oca/web,/mnt/oca/queue
smtp_server = mailpit
smtp_port = 1025
admin_passwd = YOUR_ADMIN_PASSWORD
server_wide_modules = web,queue_job
workers = 6

[queue_job]
channels = root:4,root.newsassistant:2,root.email_extraction:1