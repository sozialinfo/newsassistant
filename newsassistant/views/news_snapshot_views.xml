<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List view -->
    <record id="news_snapshot_view_list" model="ir.ui.view">
        <field name="name">news.snapshot.list</field>
        <field name="model">news.snapshot</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="source_id" widget="many2one_link"/>
                <field name="is_listing" optional="show"/>
                <field name="parent_id" optional="hidden"/>
                <field name="captured_at"/>
                <field name="article_count"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="news_snapshot_view_form" model="ir.ui.view">
        <field name="name">news.snapshot.form</field>
        <field name="model">news.snapshot</field>
        <field name="arch" type="xml">
            <form create="0">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="source_id" widget="many2one_link"/>
                            <field name="captured_at"/>
                            <field name="url" widget="url"/>
                            <field name="is_listing"/>
                            <field name="article_count"/>
                        </group>
                        <group>
                            <field name="parent_id" widget="many2one_link"
                                   invisible="not parent_id"/>
                            <field name="child_ids" widget="many2many_tags"
                                   invisible="not child_ids"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content">
                            <field name="raw_content" nolabel="1" readonly="1" widget="html"/>
                        </page>
                        <page string="Child Snapshots"
                              invisible="not is_listing">
                            <field name="child_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="captured_at"/>
                                    <field name="article_count"/>
                                </list>
                            </field>
                        </page>
                        <page string="Articles"
                              invisible="is_listing">
                            <field name="article_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="title"/>
                                    <field name="date"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'scraped'"
                                           decoration-warning="state == 'pending'"
                                           decoration-danger="state == 'error'"
                                           decoration-muted="state == 'skipped'"/>
                                    <field name="scrape_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="news_snapshot_action" model="ir.actions.act_window">
        <field name="name">Snapshots</field>
        <field name="res_model">news.snapshot</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
