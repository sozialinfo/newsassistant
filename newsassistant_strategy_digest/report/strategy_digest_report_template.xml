<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_strategy_digest">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Title block -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h1 t-field="doc.name"/>
                                <p class="text-muted">
                                    <span t-field="doc.date_from"/> – <span t-field="doc.date_to"/>
                                </p>
                            </div>
                        </div>

                        <!-- Brief content (AI-generated HTML) -->
                        <div t-if="doc.brief" t-out="doc.brief"/>

                        <!-- Fallback if no brief generated -->
                        <div t-else="">
                            <p class="text-muted font-italic">
                                No brief generated yet. Click "Generate Brief" in the digest form.
                            </p>
                        </div>

                        <!-- Article reference list (if articles linked) -->
                        <div t-if="doc.article_ids" class="mt-4">
                            <h3>Referenced Articles</h3>
                            <table class="table table-sm" style="font-size:9pt;">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Title</th>
                                        <th>Source</th>
                                        <th>Date</th>
                                        <th>Labels</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.article_ids" t-as="article">
                                        <tr>
                                            <td t-esc="article_index + 1"/>
                                            <td>
                                                <t t-if="article.url">
                                                    <a t-att-href="article.url"><span t-field="article.title"/></a>
                                                </t>
                                                <t t-else="">
                                                    <span t-field="article.title"/>
                                                </t>
                                            </td>
                                            <td><span t-field="article.source_id"/></td>
                                            <td><span t-field="article.date"/></td>
                                            <td>
                                                <t t-foreach="article.strategy_label_ids" t-as="label">
                                                    <span t-field="label.name"/>
                                                    <t t-if="not label_last">, </t>
                                                </t>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <!-- Strategies summary -->
                        <div t-if="doc.strategy_ids" class="mt-2">
                            <h3>Strategies</h3>
                            <ul>
                                <t t-foreach="doc.strategy_ids" t-as="strategy">
                                    <li>
                                        <strong t-field="strategy.name"/>
                                        <t t-if="strategy.date_from or strategy.date_to">
                                            (<span t-field="strategy.date_from"/>
                                            <t t-if="strategy.date_from and strategy.date_to"> – </t>
                                            <span t-field="strategy.date_to"/>)
                                        </t>
                                    </li>
                                </t>
                            </ul>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
