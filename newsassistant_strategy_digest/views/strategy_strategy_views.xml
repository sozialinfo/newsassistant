<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Digest strategy form extensions -->
    <record id="strategy_strategy_view_form_digest" model="ir.ui.view">
        <field name="name">strategy.strategy.form.digest</field>
        <field name="model">strategy.strategy</field>
        <field name="inherit_id" ref="newsassistant_strategy.strategy_strategy_view_form"/>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <group position="inside">
                <group string="Labels">
                    <field name="label_ids" widget="many2many_tags"
                           options="{'color_field': 'color'}" nolabel="1"/>
                </group>
            </group>
            <xpath expr="//div[@name='prompt_sections']" position="inside">
                <div class="card mt-3 mb-3">
                    <div class="card-header">
                        <strong>Digest</strong>
                    </div>
                    <div class="card-body">
                        <field name="digest_prompt" nolabel="1"
                               style="min-height: 6em;"/>
                        <button name="action_distill_digest_prompt"
                                string="Distill Digest Prompt"
                                type="object"
                                class="btn btn-secondary mt-2"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Inject label_ids into list view -->
    <record id="strategy_strategy_view_list_digest" model="ir.ui.view">
        <field name="name">strategy.strategy.list.digest</field>
        <field name="model">strategy.strategy</field>
        <field name="inherit_id" ref="newsassistant_strategy.strategy_strategy_view_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_to']" position="after">
                <field name="label_ids" widget="many2many_tags"
                       options="{'color_field': 'color'}"/>
            </xpath>
        </field>
    </record>

    <!-- Inject label_ids into search view -->
    <record id="strategy_strategy_view_search_digest" model="ir.ui.view">
        <field name="name">strategy.strategy.search.digest</field>
        <field name="model">strategy.strategy</field>
        <field name="inherit_id" ref="newsassistant_strategy.strategy_strategy_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="label_ids"/>
            </xpath>
        </field>
    </record>
</odoo>