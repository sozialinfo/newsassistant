<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List view -->
    <record id="strategy_label_view_list" model="ir.ui.view">
        <field name="name">strategy.label.list</field>
        <field name="model">strategy.label</field>
        <field name="arch" type="xml">
            <list string="Strategy Labels" editable="top">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="strategy_label_view_form" model="ir.ui.view">
        <field name="name">strategy.label.form</field>
        <field name="model">strategy.label</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Window action -->
    <record id="strategy_label_action" model="ir.actions.act_window">
        <field name="name">Strategy Labels</field>
        <field name="res_model">strategy.label</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>