# News Assistant — environment variables
# Copy this file to .env and fill in your values.

# Required: Infomaniak AI Services API key
# Used for all AI calls: article extraction, triage, strategy evaluation, digest generation.
# Obtain at: https://manager.infomaniak.com/v3/products/ai-services
INFOMANIAK_AI_API_KEY=

# Optional: Pixabay API key
# Used as a fallback image source for blog posts when an article has no header image.
# Can also be set via the Odoo Settings UI (News Assistant → Configuration → Settings).
# Obtain at: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Postgres database password (default: odoo)
POSTGRES_PASSWORD=odoo

# Optional: crawl4ai API token for production deployments.
# In docker-compose local dev, defaults to "dev-token" automatically.
# Set this to a secure value for production.
CRAWL4AI_API_TOKEN=
