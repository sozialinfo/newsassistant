<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="strategy_strategy_view_form_watch" model="ir.ui.view">
        <field name="name">strategy.strategy.form.watch</field>
        <field name="model">strategy.strategy</field>
        <field name="inherit_id" ref="newsassistant_strategy.strategy_strategy_view_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='prompt_sections']" position="inside">
                <div class="card mb-3">
                    <div class="card-header">
                        <strong>Watch</strong>
                    </div>
                    <div class="card-body">
                        <field name="watch_prompt" nolabel="1"
                               style="min-height: 6em;"/>
                        <button name="action_distill_watch_prompt"
                                string="Distill Watch Prompt"
                                type="object"
                                class="btn btn-secondary mt-2"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>