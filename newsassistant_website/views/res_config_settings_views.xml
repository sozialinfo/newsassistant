<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_newsassistant_website" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.newsassistant_website</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="newsassistant.res_config_settings_view_form_newsassistant"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='newsassistant']" position="inside">
                <block title="Scraping" name="newsassistant_scraping_settings">
                    <setting string="crawl4ai Server URL"
                             help="URL of the self-hosted crawl4ai server used for all web page fetching. Default: http://crawl4ai:11235">
                        <div class="content-group">
                            <div class="mt16" style="width: 100%;">
                                <field name="newsassistant_crawl4ai_url"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
