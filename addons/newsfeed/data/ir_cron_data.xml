<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Daily digest cron job -->
        <record id="ir_cron_digest_all" model="ir.cron">
            <field name="name">Newsfeed: Process Digest</field>
            <field name="model_id" ref="newsassistant.model_news_article"/>
            <field name="state">code</field>
            <field name="code">model._cron_digest_all_impl()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
