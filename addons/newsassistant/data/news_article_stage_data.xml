<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="news_article_stage_new" model="news.article.stage">
            <field name="name">New</field>
            <field name="sequence">10</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="news_article_stage_shortlist" model="news.article.stage">
            <field name="name">Shortlist</field>
            <field name="sequence">20</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="news_article_stage_published" model="news.article.stage">
            <field name="name">Published</field>
            <field name="sequence">30</field>
            <field name="fold" eval="True"/>
        </record>

        <record id="news_article_stage_discarded" model="news.article.stage">
            <field name="name">Discarded</field>
            <field name="sequence">40</field>
            <field name="fold" eval="True"/>
        </record>
    </data>
</odoo>
