        <record id="news_article_stage_new" model="news.article.stage">
            <field name="name">New</field>
            <field name="sequence">10</field>
            <field name="fold" eval="False"/>
        </record>

        <record id="news_article_stage_relevant" model="news.article.stage">
            <field name="name">Relevant</field>
            <field name="sequence">20</field>
            <field name="fold" eval="False"/>
