<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List view -->
    <record id="news_source_view_list" model="ir.ui.view">
        <field name="name">news.source.list</field>
        <field name="model">news.source</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="source_type" widget="badge"
                       decoration-info="source_type == 'website'"
                       decoration-primary="source_type == 'email'"/>
                <field name="url" widget="url" optional="show"
                       invisible="source_type != 'website'"/>
                <field name="sender_domain" optional="show"
                       invisible="source_type != 'email'"/>
                <field name="is_scraping" widget="boolean" string="Scraping"
                       decoration-info="is_scraping"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'ok'"
                       decoration-danger="state == 'error'"/>
                <field name="last_scrape_date"/>
                <field name="article_count"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="news_source_view_form" model="ir.ui.view">
        <field name="name">news.source.form</field>
        <field name="model">news.source</field>
        <field name="arch" type="xml">
            <form>
                <header>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(newsassistant.news_article_action)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-newspaper-o"
                                context="{'search_default_source_id': id}">
                            <field name="article_count" widget="statinfo" string="Articles"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Source Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="source_type" widget="radio"/>
                            <field name="url" widget="url"
                                   invisible="source_type != 'website'"
                                   required="source_type == 'website'"/>
                            <field name="sender_domain"
                                   invisible="source_type != 'email'"
                                   required="source_type == 'email'"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'ok'"
                                   decoration-danger="state == 'error'"/>
                            <field name="last_scrape_date"/>
                        </group>
                    </group>
                    <group string="Error Details" invisible="state != 'error'">
                        <field name="error_message" nolabel="1" colspan="2"/>
                    </group>
                    <notebook>
                        <!-- Snapshots tab (all users) -->
                        <page string="Snapshots">
                            <field name="snapshot_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="captured_at"/>
                                    <field name="article_count"/>
                                </list>
                            </field>
                        </page>
                        <!-- Log tab (admin only) -->
                        <page string="Log" groups="newsassistant.newsassistant_group_admin">
                            <field name="log_ids" nolabel="1" readonly="1">
                                <list limit="20">
                                    <field name="timestamp"/>
                                    <field name="level" widget="badge"
                                           decoration-success="level == 'success'"
                                           decoration-warning="level == 'warning'"
                                           decoration-danger="level == 'error'"/>
                                    <field name="category"/>
                                    <field name="snapshot_id" widget="many2one_link" optional="show"/>
                                    <field name="article_id" widget="many2one_link"/>
                                    <field name="message"/>
                                    <field name="duration" widget="float_time"/>
                                    <field name="job_id" widget="many2one_link" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="news_source_view_search" model="ir.ui.view">
        <field name="name">news.source.search</field>
        <field name="model">news.source</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="url"/>
                <field name="sender_domain"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Archived" domain="[('active', '=', False)]"/>
                <separator/>
                <filter name="type_website" string="Website Sources"
                        domain="[('source_type', '=', 'website')]"/>
                <filter name="type_email" string="Email Sources"
                        domain="[('source_type', '=', 'email')]"/>
                <separator/>
                <filter name="state_ok" string="OK" domain="[('state', '=', 'ok')]"/>
                <filter name="state_error" string="Has Errors" domain="[('state', '=', 'error')]"/>
                <filter name="never_scraped" string="Never Scraped"
                        domain="[('last_scrape_date', '=', False)]"/>
                <filter name="stale" string="Stale"
                        domain="[('last_scrape_date', '&lt;', (context_today() - datetime.timedelta(days=7)).strftime('%%Y-%%m-%%d'))]"/>
            </search>
        </field>
    </record>
</odoo>
