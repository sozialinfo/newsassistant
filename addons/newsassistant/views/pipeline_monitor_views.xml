<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Pipeline Monitor Form View (Dashboard) -->
    <record id="pipeline_monitor_view_form" model="ir.ui.view">
        <field name="name">news.pipeline.monitor.form</field>
        <field name="model">news.pipeline.monitor</field>
        <field name="arch" type="xml">
            <form string="Pipeline Monitor" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sources_with_errors" type="object"
                                class="oe_stat_button" icon="fa-exclamation-triangle">
                            <field name="sources_with_errors" widget="statinfo"
                                   string="Sources with Errors"/>
                        </button>
                        <button name="action_view_articles_pending" type="object"
                                class="oe_stat_button" icon="fa-clock-o">
                            <field name="articles_pending" widget="statinfo"
                                   string="Articles Pending"/>
                        </button>
                        <button name="action_view_articles_with_errors" type="object"
                                class="oe_stat_button" icon="fa-times-circle">
                            <field name="articles_with_errors" widget="statinfo"
                                   string="Articles with Errors"/>
                        </button>
                        <button name="action_view_recent_failures" type="object"
                                class="oe_stat_button" icon="fa-warning">
                            <field name="recent_failures" widget="statinfo"
                                   string="Failures (24h)"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>Pipeline Monitor</h1>
                    </div>
                    <div class="alert alert-info" role="alert">
                        <p>Click on any stat button above to view details.</p>
                        <p>This dashboard shows the current state of the scraping pipeline.</p>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Pipeline Monitor Action -->
    <record id="pipeline_monitor_action" model="ir.actions.act_window">
        <field name="name">Pipeline Monitor</field>
        <field name="res_model">news.pipeline.monitor</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'form_view_initial_mode': 'readonly'}</field>
    </record>

    <!-- Source Log List View -->
    <record id="news_source_log_view_list" model="ir.ui.view">
        <field name="name">news.source.log.list</field>
        <field name="model">news.source.log</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false">
                <field name="timestamp"/>
                <field name="source_id"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'success'"
                       decoration-danger="status == 'error'"/>
                <field name="articles_found"/>
                <field name="duration"/>
                <field name="error_message"/>
            </list>
        </field>
    </record>

    <!-- Article Log List View -->
    <record id="news_article_log_view_list" model="ir.ui.view">
        <field name="name">news.article.log.list</field>
        <field name="model">news.article.log</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false">
                <field name="timestamp"/>
                <field name="article_id"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'success'"
                       decoration-danger="status == 'error'"/>
                <field name="duration"/>
                <field name="error_message"/>
            </list>
        </field>
    </record>
</odoo>
