<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Source Action (defined here since source views reference article action) -->
    <record id="news_source_action" model="ir.actions.act_window">
        <field name="name">Sources</field>
        <field name="res_model">news.source</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="news_source_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first news source
            </p>
            <p>
                Configure the websites to monitor for news articles.
            </p>
        </field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_news_assistant_root"
              name="News Assistant"
              web_icon="newsassistant,static/description/icon.png"
              sequence="90"/>

    <menuitem id="menu_news_articles"
              name="Articles"
              parent="menu_news_assistant_root"
              action="news_article_action"
              sequence="10"/>

    <menuitem id="menu_news_sources"
              name="Sources"
              parent="menu_news_assistant_root"
              action="news_source_action"
              sequence="20"/>

    <menuitem id="menu_pipeline_monitor"
              name="Pipeline Monitor"
              parent="menu_news_assistant_root"
              action="pipeline_monitor_action"
              groups="newsassistant.newsassistant_group_admin"
              sequence="30"/>
</odoo>
