<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Job function: scrape listing page (Stage 1) -->
    <record id="job_function_news_source_scrape_listing" model="queue.job.function">
        <field name="model_id" ref="newsassistant.model_news_source"/>
        <field name="method">_scrape_listing</field>
        <field name="channel_id" ref="newsassistant.channel_newsassistant"/>
        <field name="retry_pattern" eval="{1: 300, 3: 900, 5: 3600}"/>
    </record>

    <!-- Job function: fetch article page and create snapshot -->
    <record id="job_function_news_source_fetch_snapshot" model="queue.job.function">
        <field name="model_id" ref="newsassistant.model_news_source"/>
        <field name="method">_fetch_and_create_snapshot</field>
        <field name="channel_id" ref="newsassistant.channel_newsassistant"/>
        <field name="retry_pattern" eval="{1: 300, 3: 900, 5: 3600}"/>
    </record>


</odoo>
