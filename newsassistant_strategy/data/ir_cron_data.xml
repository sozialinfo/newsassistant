<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Hourly strategy evaluation cron job -->
        <record id="ir_cron_strategy_eval" model="ir.cron">
            <field name="name">News Assistant: Strategy Evaluation</field>
            <field name="model_id" ref="newsassistant.model_news_article"/>
            <field name="state">code</field>
            <field name="code">model._cron_strategy_eval_impl()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>